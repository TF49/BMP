# Application
APP_NAME=bmp-agent
APP_ENV=development
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=json

# OpenAI-compatible model (optional in P0)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=your_model_name
LLM_TIMEOUT_SECONDS=30

# External dependencies are disabled when left empty
DATABASE_URL=
REDIS_URL=
EXTERNAL_HEALTH_CHECKS=false
HEALTH_CHECK_TIMEOUT_SECONDS=3

# Agent Context Verification (static for dev, signed for production)
AGENT_CONTEXT_MODE=static
STATIC_AGENT_CONTEXT_TOKEN=dev-only-context-token
STATIC_AGENT_USER_ID=local-user
STATIC_AGENT_USER_ROLE=MEMBER
STATIC_AGENT_VENUE_ID=
AGENT_CONTEXT_SECRET=
SESSION_TTL_SECONDS=3600

# Agent storage backend (memory for dev, postgres for integration/production)
AGENT_STORAGE_BACKEND=memory
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Java Tool Integration (P1+)
JAVA_TOOL_BASE_URL=http://127.0.0.1:9090
JAVA_SERVICE_TOKEN=
TOOL_CONNECT_TIMEOUT_SECONDS=2.0
TOOL_READ_TIMEOUT_SECONDS=10.0
TOOL_MAX_RETRIES=2

# Agent Rate Limiting (P1+)
AGENT_RATE_LIMIT_MAX_REQUESTS=20
AGENT_RATE_LIMIT_WINDOW_SECONDS=60
