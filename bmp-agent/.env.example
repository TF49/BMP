# 应用配置
APP_NAME=bmp-agent
APP_ENV=development
APP_PORT=8000
APP_DEBUG=true

# 模型配置
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# 数据库配置
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bmp_agent
# 开发环境可使用 SQLite
# DATABASE_URL=sqlite+aiosqlite:///./bmp_agent.db

# Redis 配置
REDIS_URL=redis://localhost:6379/0
# 开发环境可留空使用内存缓存
# REDIS_URL=

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# 服务密钥（用于 Java Tool 认证）
AGENT_SERVICE_KEY=your_service_key_here
AGENT_CONTEXT_SECRET=your_context_secret_here

# 可观测性
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
